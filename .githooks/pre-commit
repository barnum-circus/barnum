#!/bin/bash
# Pre-commit hook stub.
# Sources pre-commit-full.sh if it exists (opt-in).
# To enable: the file is already there, this just delegates.
# To disable: remove or rename pre-commit-full.sh.

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -x "$HOOK_DIR/pre-commit-full.sh" ]; then
    exec "$HOOK_DIR/pre-commit-full.sh" "$@"
fi
