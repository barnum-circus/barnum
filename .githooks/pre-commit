#!/bin/bash
# Pre-commit hook: runs fmt, check, clippy, test, and udeps
# Format runs first (modifies files), then check/clippy/test/udeps run in parallel
# Skips cargo commands if no Rust files are staged

set -e

# Check if any Rust-related files are staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
RUST_FILES=$(echo "$STAGED_FILES" | grep -E '\.(rs|toml)$' || true)

if [ -z "$RUST_FILES" ]; then
    echo "No Rust files changed, skipping cargo checks."
    exit 0
fi

echo "Running cargo fmt..."
cargo fmt --all

echo "Regenerating schemas..."
cargo run -p barnum_cli --bin build_schemas 2>/dev/null

echo "Regenerating CLI schema..."
cargo run -p barnum_cli --bin build_cli_schema 2>/dev/null

# Re-stage only files that were already staged (not unrelated unstaged changes)
echo "$STAGED_FILES" | xargs git add
git add libs/barnum/barnum-config-schema.json
git add libs/barnum/barnum-config-schema.zod.ts
git add libs/barnum/barnum-cli-schema.zod.ts

# Create temp directory for output files
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

# Build CLI binary first (tests spawn it as subprocess)
echo "Building CLI binary..."
cargo build -p troupe_cli > "$TEMP_DIR/build.log" 2>&1 || { echo "cargo build failed:"; cat "$TEMP_DIR/build.log"; exit 1; }

# Run check, clippy, test, and udeps in parallel
echo "Running cargo check, clippy, test, and udeps in parallel..."

# Start background jobs
cargo check --workspace --all-targets > "$TEMP_DIR/check.log" 2>&1 &
CHECK_PID=$!

cargo clippy --workspace --all-targets -- -D warnings > "$TEMP_DIR/clippy.log" 2>&1 &
CLIPPY_PID=$!

SKIP_IPC_TESTS=1 cargo test --workspace -- --test-threads=1 > "$TEMP_DIR/test.log" 2>&1 &
TEST_PID=$!

# udeps is optional
if rustup run nightly cargo udeps --help > /dev/null 2>&1; then
    cargo +nightly udeps --workspace --all-targets > "$TEMP_DIR/udeps.log" 2>&1 &
    UDEPS_PID=$!
else
    UDEPS_PID=""
fi

# Wait for all jobs and collect exit codes
FAILED=""

wait $CHECK_PID || { echo "cargo check failed:"; cat "$TEMP_DIR/check.log"; FAILED="$FAILED check"; }
wait $CLIPPY_PID || { echo "cargo clippy failed:"; cat "$TEMP_DIR/clippy.log"; FAILED="$FAILED clippy"; }
wait $TEST_PID || { echo "cargo test failed:"; cat "$TEMP_DIR/test.log"; FAILED="$FAILED test"; }
if [ -n "$UDEPS_PID" ]; then
    wait $UDEPS_PID || { echo "cargo udeps failed:"; cat "$TEMP_DIR/udeps.log"; FAILED="$FAILED udeps"; }
fi

if [ -n "$FAILED" ]; then
    echo "Pre-commit checks failed:$FAILED"
    exit 1
fi

echo "Pre-commit checks passed!"
