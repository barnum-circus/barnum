#!/bin/bash
# Pre-commit hook: only runs checks relevant to staged file types.
# Markdown-only commits skip everything.

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
RUST_FILES=$(echo "$STAGED_FILES" | grep -E '\.(rs|toml)$' || true)
DOCS_FILES=$(echo "$STAGED_FILES" | grep -E '^docs-website/' || true)

if [ -z "$TS_FILES" ] && [ -z "$RUST_FILES" ] && [ -z "$DOCS_FILES" ]; then
    exit 0
fi

# -- Lockfile check: every package.json with a tsconfig must have a committed lockfile --

echo "Checking lockfiles..."
for demo in demos/*/; do
    if [ -f "$demo/package.json" ]; then
        if ! git ls-files --error-unmatch "$demo/pnpm-lock.yaml" > /dev/null 2>&1; then
            echo "Missing committed pnpm-lock.yaml in $demo (run: cd $demo && pnpm install)"
            exit 1
        fi
    fi
done

# -- TypeScript checks (if TS files staged) --

if [ -n "$TS_FILES" ]; then
    echo "Running oxlint..."
    pnpm --filter barnum run lint || { echo "oxlint failed"; exit 1; }

    echo "Running prettier --check..."
    pnpm --filter barnum exec prettier --check 'src/**/*.ts' || { echo "prettier check failed (run: pnpm --filter barnum exec prettier --write 'src/**/*.ts')"; exit 1; }

    TSC_BARNUM="$(pwd)/libs/barnum/node_modules/.bin/tsc"
    TSC_DOCS="$(pwd)/docs-website/node_modules/.bin/tsc"

    echo "Running TypeScript type-check (barnum)..."
    $TSC_BARNUM --noEmit -p libs/barnum/tsconfig.json || { echo "tsc --noEmit failed (barnum)"; exit 1; }

    # Typecheck demos + docs-website in parallel
    TMPDIR_TC=$(mktemp -d)
    PIDS=""

    for demo in demos/*/; do
        if [ -f "$demo/tsconfig.json" ]; then
            echo "Running TypeScript type-check ($demo)..."
            ( $TSC_BARNUM --noEmit -p "$demo/tsconfig.json" > "$TMPDIR_TC/$(basename $demo).out" 2>&1 || echo "FAIL:$demo" >> "$TMPDIR_TC/failures" ) &
            PIDS="$PIDS $!"
        fi
    done

    if [ -n "$DOCS_FILES" ]; then
        echo "Running docs-website typecheck..."
        ( $TSC_DOCS --noEmit -p docs-website/tsconfig.json > "$TMPDIR_TC/docs-website.out" 2>&1 || echo "FAIL:docs-website" >> "$TMPDIR_TC/failures" ) &
        PIDS="$PIDS $!"
    fi

    for pid in $PIDS; do wait "$pid" || true; done

    if [ -f "$TMPDIR_TC/failures" ]; then
        echo ""
        echo "TypeScript type-check failures:"
        while IFS= read -r line; do
            name="${line#FAIL:}"
            echo "--- $name ---"
            cat "$TMPDIR_TC/$(basename $name).out"
        done < "$TMPDIR_TC/failures"
        rm -rf "$TMPDIR_TC"
        exit 1
    fi
    rm -rf "$TMPDIR_TC"

elif [ -n "$DOCS_FILES" ]; then
    # Only docs files staged, no TS library/demo files
    echo "Running docs-website typecheck..."
    TSC_DOCS="$(pwd)/docs-website/node_modules/.bin/tsc"
    $TSC_DOCS --noEmit -p docs-website/tsconfig.json || { echo "tsc failed (docs-website)"; exit 1; }
fi

# -- Rust checks (if Rust files staged) --

if [ -n "$RUST_FILES" ]; then
    echo "Running cargo fmt..."
    cargo fmt --all

    # Re-stage only files that were already staged (not unrelated unstaged changes)
    echo "$STAGED_FILES" | xargs git add

    echo "Building CLI binaries..."
    cargo build -p barnum_cli || { echo "cargo build failed"; exit 1; }

    echo "Running cargo check..."
    cargo check --workspace --all-targets || { echo "cargo check failed"; exit 1; }

    echo "Running cargo clippy..."
    cargo clippy --workspace --all-targets -- -D warnings || { echo "cargo clippy failed"; exit 1; }

    # udeps is optional
    if rustup run nightly cargo udeps --help > /dev/null 2>&1; then
        echo "Running cargo udeps..."
        cargo +nightly udeps --workspace --all-targets || { echo "cargo udeps failed"; exit 1; }
    fi
fi

# -- Tests (if any code changed) --

echo "Running tests..."
pnpm test || { echo "pnpm test failed"; exit 1; }

echo "Pre-commit checks passed!"
