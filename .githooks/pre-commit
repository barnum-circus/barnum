#!/bin/bash
# Pre-commit hook: runs fmt, check, clippy, barnum tests
# Skips cargo commands if no Rust files are staged

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
RUST_FILES=$(echo "$STAGED_FILES" | grep -E '\.(rs|toml)$' || true)

# TypeScript type-checking (always runs if TS files are staged)
if [ -n "$TS_FILES" ]; then
    echo "Running TypeScript type-check (barnum)..."
    pnpm --filter barnum exec tsc --noEmit || { echo "tsc --noEmit failed (barnum)"; exit 1; }
    echo "Running TypeScript type-check (demos/simple-workflow)..."
    (cd demos/simple-workflow && pnpm exec tsc --noEmit) || { echo "tsc --noEmit failed (demos)"; exit 1; }
fi

if [ -z "$RUST_FILES" ]; then
    echo "No Rust files changed, skipping cargo checks."
    exit 0
fi

echo "Running cargo fmt..."
cargo fmt --all

# Re-stage only files that were already staged (not unrelated unstaged changes)
echo "$STAGED_FILES" | xargs git add

# Build CLI binaries first (tests spawn them as subprocesses)
echo "Building CLI binaries..."
cargo build -p barnum_cli || { echo "cargo build failed"; exit 1; }

# Run demos (requires CLI binary built above)
echo "Running demos..."
(cd demos/simple-workflow && pnpm exec tsx run.ts > /dev/null) || { echo "demo run.ts failed"; exit 1; }
(cd demos/simple-workflow && pnpm exec tsx run-parallel.ts > /dev/null) || { echo "demo run-parallel.ts failed"; exit 1; }
(cd demos/simple-workflow && pnpm exec tsx run-loop.ts > /dev/null) || { echo "demo run-loop.ts failed"; exit 1; }

echo "Running cargo check..."
cargo check --workspace --all-targets || { echo "cargo check failed"; exit 1; }

echo "Running cargo clippy..."
cargo clippy --workspace --all-targets -- -D warnings || { echo "cargo clippy failed"; exit 1; }

# Only run barnum-related tests (skip troupe/agent tests)
TROUPE_BIN="./target/debug/troupe"
echo "Running tests..."
BARNUM_TEST_CMD="cargo test -p barnum_ast -p barnum_engine -p barnum_cli -p barnum_event_loop -- --test-threads=1"
if [ -x "$TROUPE_BIN" ]; then
    RESULT=$("$TROUPE_BIN" submit_task --pool cmd --notify file \
        --data "{\"kind\": \"Task\", \"task\": {\"instructions\": \"pre-commit tests\", \"data\": {\"cmd\": \"cd $(pwd) && $BARNUM_TEST_CMD 2>&1\"}}}" 2>/dev/null) || true
    if echo "$RESULT" | grep -q '"kind":"Failed"'; then
        echo "cargo test failed (via command pool):"
        echo "$RESULT"
        exit 1
    fi
else
    SKIP_IPC_TESTS=1 $BARNUM_TEST_CMD || { echo "cargo test failed"; exit 1; }
fi

# udeps is optional
if rustup run nightly cargo udeps --help > /dev/null 2>&1; then
    echo "Running cargo udeps..."
    cargo +nightly udeps --workspace --all-targets || { echo "cargo udeps failed"; exit 1; }
fi

echo "Pre-commit checks passed!"
