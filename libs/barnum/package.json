{
  "name": "@barnum/barnum",
  "version": "0.2.4",
  "description": "Barnum workflow engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "barnum": "cli.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/"
  },
  "author": "Robert Balicki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barnum-circus/barnum.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist/**/*",
    "src/**/*.ts",
    "cli.cjs",
    "artifacts/**/*"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@oxlint/binding-darwin-arm64": "^1.57.0",
    "@types/node": "^25.5.0",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
