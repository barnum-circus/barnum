digraph Barnum {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "Split" [shape=box, label="Split", style=filled, fillcolor="#e3f2fd"];
  "Process" [shape=box, label="Process", style=filled, fillcolor="#e3f2fd"];
  "Collect" [shape=box, peripheries=2, label="Collect", style=filled, fillcolor="#e3f2fd"];

  "Split" -> "Process";
  "Process" -> "Collect";
}
