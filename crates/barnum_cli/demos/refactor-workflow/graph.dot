digraph Barnum {
  rankdir=TB;
  node [fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "ListFiles" [shape=box, label="ListFiles", style=filled, fillcolor="#e3f2fd"];
  "AnalyzeFile" [shape=box, label="AnalyzeFile", style=filled, fillcolor="#e3f2fd"];
  "ProcessRefactorList" [shape=box, label="ProcessRefactorList", style=filled, fillcolor="#e3f2fd"];
  "CommitFile" [shape=box, peripheries=2, label="CommitFile", style=filled, fillcolor="#e3f2fd"];

  "ListFiles" -> "AnalyzeFile";
  "AnalyzeFile" -> "ProcessRefactorList";
  "ProcessRefactorList" -> "ProcessRefactorList";
  "ProcessRefactorList" -> "CommitFile";
}
