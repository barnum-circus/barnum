// Example invocation:
// pnpm dlx @barnum/barnum run --config config.jsonc --entrypoint-value '{"folder": "./src"}'
//
// NOTE: This workflow is not included in run-all-demos.sh because it requires
// a real codebase and Claude agents to function.
{
  "entrypoint": "ListFiles",
  "options": {
    "max_retries": 2
  },
  "steps": [
    {
      "name": "ListFiles",
      "action": {
        "kind": "Pool",
        "params": {
          "instructions": {"kind": "Link", "path": "list-files.md"}
        }
      },
      "next": ["AnalyzeFile"]
    },
    {
      "name": "AnalyzeFile",
      "action": {
        "kind": "Pool",
        "params": {
          "instructions": {"kind": "Link", "path": "analyze-file.md"}
        }
      },
      "next": ["ProcessRefactorList"]
    },
    {
      "name": "ProcessRefactorList",
      "action": {
        "kind": "Pool",
        "params": {
          "instructions": {"kind": "Link", "path": "process-refactor-list.md"}
        }
      },
      "next": ["ProcessRefactorList", "CommitFile"]
    },
    {
      "name": "CommitFile",
      "action": {
        "kind": "Pool",
        "params": {
          "instructions": {"kind": "Link", "path": "commit-file.md"}
        }
      },
      "next": []
    }
  ]
}
