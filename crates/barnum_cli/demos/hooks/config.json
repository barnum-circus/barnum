{
  "entrypoint": "Process",
  "options": {
    "max_retries": 0
  },
  "steps": [
    {
      "name": "Process",
      "action": {
        "kind": "Command",
        "params": {
          "script": "./process.sh"
        }
      },
      "finally": { "kind": "Command", "params": { "script": "./finally-hook.sh" } },
      "next": ["Cleanup"]
    },
    {
      "name": "Cleanup",
      "action": {
        "kind": "Command",
        "params": {
          "script": "echo '[]'"
        }
      },
      "next": []
    }
  ]
}
