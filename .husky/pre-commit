#!/bin/bash
# Pre-commit hook: only runs checks relevant to staged file types.
# Markdown-only commits skip everything.
# Output is suppressed on success — only shown on failure.

set -e

# Run a command quietly. Shows label, suppresses output on success,
# dumps full output on failure.
run_quiet() {
    local label="$1"
    shift
    echo "$label..."
    local tmpfile
    tmpfile=$(mktemp)
    if "$@" > "$tmpfile" 2>&1; then
        rm -f "$tmpfile"
    else
        local exit_code=$?
        echo "FAILED: $label"
        cat "$tmpfile"
        rm -f "$tmpfile"
        exit $exit_code
    fi
}

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
RUST_FILES=$(echo "$STAGED_FILES" | grep -E '\.(rs|toml)$' || true)
DOCS_FILES=$(echo "$STAGED_FILES" | grep -E '^docs-website/' || true)

if [ -z "$TS_FILES" ] && [ -z "$RUST_FILES" ] && [ -z "$DOCS_FILES" ]; then
    exit 0
fi

# -- Lockfile check: every package.json with a tsconfig must have a committed lockfile --

echo "Checking lockfiles..."
for demo in demos/*/; do
    if [ -f "$demo/package.json" ]; then
        if ! git ls-files --error-unmatch "$demo/pnpm-lock.yaml" > /dev/null 2>&1; then
            echo "Missing committed pnpm-lock.yaml in $demo (run: cd $demo && pnpm install)"
            exit 1
        fi
    fi
done

# -- TypeScript checks (if TS files staged) --

if [ -n "$TS_FILES" ]; then
    run_quiet "Running oxlint" pnpm --filter @barnum/barnum run lint

    run_quiet "Running prettier --check" pnpm --filter @barnum/barnum exec prettier --check 'src/**/*.ts' 'tests/**/*.ts' '../../demos/**/*.ts'

    if [ -n "$DOCS_FILES" ]; then
        run_quiet "Running turbo typecheck" pnpm exec turbo run typecheck
    else
        run_quiet "Running turbo typecheck" pnpm exec turbo run typecheck --filter='@barnum/barnum' --filter='./demos/*'
    fi
fi

# -- Docs-only checks (no TS library/demo files staged) --

if [ -z "$TS_FILES" ] && [ -n "$DOCS_FILES" ]; then
    run_quiet "Running docs-website typecheck" pnpm exec turbo run typecheck --filter=barnum-docs
fi

# -- Rust checks (if Rust files staged) --

if [ -n "$RUST_FILES" ]; then
    # cargo fmt modifies files in place — run directly (no output to suppress)
    echo "Running cargo fmt..."
    cargo fmt --all 2>/dev/null

    # Re-stage only files that were already staged (not unrelated unstaged changes)
    echo "$STAGED_FILES" | xargs git add

    run_quiet "Building CLI binaries" cargo build -p barnum_cli

    run_quiet "Running cargo check" cargo check --workspace --all-targets

    run_quiet "Running cargo clippy" cargo clippy --workspace --all-targets -- -D warnings

    # udeps is optional
    if rustup run nightly cargo udeps --help > /dev/null 2>&1; then
        run_quiet "Running cargo udeps" cargo +nightly udeps --workspace --all-targets
    fi
fi

# -- Tests (if any code changed) --

run_quiet "Running tests" pnpm exec turbo run test --filter='@barnum/barnum'

echo "Pre-commit checks passed!"
